#!/usr/bin/env bash
# run_after_apply_resign-personal-scripts.sh.tmpl
#
# After every `chezmoi apply`, re-sign the personal LaunchAgent scripts
# whose plists live in ~/Library/LaunchAgents/. Chezmoi's modify/symlink
# operations strip codesign xattrs from the underlying scripts; without
# this hook they revert to "Unknown Developer" in BTM every apply.
#
# Implementation lives in ops-toolkit/tools/mac-sign/. This hook is just
# the trigger; the tool resolves the identity, walks the plists, and
# signs each ProgramArguments[0]. No hardcoded target list here.
#
# Reference: tieubao/ops-toolkit:research/2026-05-16-macos-code-signing-for-launchagents.md
set -uo pipefail

# Only run on macOS
if [ "$(uname)" != "Darwin" ]; then
    exit 0
fi

# Resolve mac-sign: PATH first, then ops-toolkit canonical location.
MAC_SIGN=""
if command -v mac-sign >/dev/null 2>&1; then
    MAC_SIGN=$(command -v mac-sign)
elif [ -x "$HOME/workspace/tieubao/ops-toolkit/tools/mac-sign/bin/mac-sign" ]; then
    MAC_SIGN="$HOME/workspace/tieubao/ops-toolkit/tools/mac-sign/bin/mac-sign"
fi

if [ -z "$MAC_SIGN" ]; then
    # mac-sign not available on this host yet; skip silently. The chezmoi
    # apply itself should not break because the helper tool isn't there.
    exit 0
fi

# Glob personal user LaunchAgent plists; mac-sign reads ProgramArguments[0]
# from each and signs the resulting path.
shopt -s nullglob
plists=(
    "$HOME"/Library/LaunchAgents/com.truonghan.*.plist
    "$HOME"/Library/LaunchAgents/mini.*.plist
)

if [ ${#plists[@]} -eq 0 ]; then
    exit 0
fi

"$MAC_SIGN" sign --from-plists "${plists[@]}" >/dev/null 2>&1 || true
