{{- $e := printf "%c" 27 -}}
#!/bin/bash
# S-62 secret-guard self-test on apply.
#
# After the hook is deployed, run the spec test matrix against the
# DEPLOYED copy. If anything fails, surface a warning via the
# dotfiles apply summary so the user notices a regression. The
# script content embeds a hash of the hook source so chezmoi re-runs
# this whenever the hook itself changes; otherwise we'd re-test on
# every apply for no reason.
#
# hook source hash: {{ include "dot_claude/hooks/secret-guard/executable_secret-guard.sh" | sha256sum }}
# stop hook hash: {{ include "dot_claude/hooks/secret-guard/executable_secret-guard-stop.sh" | sha256sum }}
# post hook hash: {{ include "dot_claude/hooks/secret-guard/executable_secret-guard-post.sh" | sha256sum }}
{{- if .headless }}
# Headless: no Claude Code, no test runner needed.
exit 0
{{- else }}
set -u

# shellcheck disable=SC1091
source "$HOME/.config/dotfiles/lib.sh" 2>/dev/null || {
    info()  { :; }
    warn()  { :; }
    err()   { :; }
    section() { :; }
}

section "Secret-guard self-test"

HOOK="$HOME/.claude/hooks/secret-guard/secret-guard.sh"

# Resolve the chezmoi source dir, FOLLOWING SYMLINKS. On this user's
# setup `~/.local/share/chezmoi` is a symlink into the actual repo
# at `~/workspace/tieubao/dotfiles/home`; without `pwd -P` we'd
# `dirname` the symlink path and look for `tests/` in the wrong place.
SOURCE_DIR_RAW="${CHEZMOI_SOURCE_DIR:-$(chezmoi source-path 2>/dev/null)}"
SOURCE_DIR=""
if [ -n "$SOURCE_DIR_RAW" ] && [ -d "$SOURCE_DIR_RAW" ]; then
    SOURCE_DIR="$(cd "$SOURCE_DIR_RAW" 2>/dev/null && pwd -P)"
fi

# Resolve the working tree (the directory CONTAINING the source dir,
# i.e. the git repo root for typical layouts where the chezmoi source
# is `<repo>/home/`).
WORKING_TREE_RAW="${CHEZMOI_WORKING_TREE:-}"
WORKING_TREE=""
if [ -n "$WORKING_TREE_RAW" ] && [ -d "$WORKING_TREE_RAW" ]; then
    WORKING_TREE="$(cd "$WORKING_TREE_RAW" 2>/dev/null && pwd -P)"
fi

# Find the test runner. Try in order:
#   1. $WORKING_TREE/tests/secret-guard.sh (preferred when chezmoi
#      reports a working tree, which is the repo root for git-managed
#      sources).
#   2. $(dirname $SOURCE_DIR)/tests/secret-guard.sh (the typical
#      `<repo>/home/` layout where the source is one level inside).
#   3. $SOURCE_DIR/tests/secret-guard.sh (flat layout, less common).
RUNNER=""
for candidate in \
    "${WORKING_TREE}/tests/secret-guard.sh" \
    "$(dirname "${SOURCE_DIR:-/nonexistent}")/tests/secret-guard.sh" \
    "${SOURCE_DIR}/tests/secret-guard.sh"; do
    if [ -n "$candidate" ] && [ -f "$candidate" ]; then
        RUNNER="$candidate"
        break
    fi
done

if [ -z "$RUNNER" ] || [ ! -f "$RUNNER" ]; then
    warn "secret-guard test runner not found" \
         "Cannot self-test the deployed hook" \
         "Verify chezmoi source-path resolves; runner expected at \$repo/tests/secret-guard.sh"
    exit 0  # warn, not fail
fi

if [ ! -x "$HOOK" ]; then
    warn "secret-guard hook not deployed" \
         "Hook missing at $HOOK" \
         "Re-run 'chezmoi apply' or check ~/.claude/hooks/secret-guard/"
    exit 0
fi

OUT=$(HOOK="$HOOK" bash "$RUNNER" 2>&1)
RC=$?

if [ "$RC" -eq 0 ]; then
    info "secret-guard: all tests pass against deployed hook"
else
    failed=$(printf '%s' "$OUT" | grep -c '^FAIL ' || true)
    warn "secret-guard self-test failed ($failed test(s))" \
         "Deployed hook does not match spec" \
         "Run 'dotfiles secret-guard test' to inspect; details at $HOME/.cache/dotfiles-apply.log"
    {
        printf '%s' "$OUT" | grep '^FAIL '
    } >>"$HOME/.cache/dotfiles-apply.log" 2>/dev/null
fi

# E1: first-run banner. On the FIRST successful self-test (no marker),
# print a one-time intro pointing at the cheatsheet + CLI verbs.
# Subsequent applies skip this. Marker file: ~/.cache/secret-guard.first-run-shown.
FIRST_RUN_MARKER="$HOME/.cache/secret-guard.first-run-shown"
if [ "$RC" -eq 0 ] && [ ! -f "$FIRST_RUN_MARKER" ]; then
    {
        echo ""
        echo "  ╭─ secret-guard is now active (S-62) ──────────────────────╮"
        echo "  │                                                          │"
        echo "  │  Blocks Claude Code tool calls that would leak           │"
        echo "  │  1Password secrets to the session transcript.            │"
        echo "  │                                                          │"
        echo "  │  Quick reference:                                        │"
        echo "  │    docs/secret-handling-cheatsheet.md  -- canonical patterns │"
        echo "  │    dotfiles secret-guard explain '<cmd>'  -- dry-run     │"
        echo "  │    dotfiles secret-guard doctor          -- health check │"
        echo "  │    dotfiles secret-guard audit-transcripts -- old leaks  │"
        echo "  │                                                          │"
        echo "  │  Mode: strict (block) | warn-only | off                  │"
        echo "  │    dotfiles secret-guard mode warn-only  -- ease-in      │"
        echo "  │                                                          │"
        echo "  ╰──────────────────────────────────────────────────────────╯"
        echo ""
    } >&2
    : >"$FIRST_RUN_MARKER" 2>/dev/null || true
fi

exit 0
{{- end }}
