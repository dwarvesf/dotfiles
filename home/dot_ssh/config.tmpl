{{- $e := printf "%c" 27 -}}
{{- if not (hasKey . "use_1password") -}}
{{-   fail (printf "\n\n%s[38;5;204m  ✗ Missing config variable: use_1password%s[0m\n    Run: %s[38;5;78mchezmoi init%s[0m\n" $e $e $e $e) -}}
{{- end -}}
# SSH config — managed by chezmoi

# Global defaults
Host *
  AddKeysToAgent yes
  IdentitiesOnly yes
  ServerAliveInterval 60
  ServerAliveCountMax 3

{{ if .use_1password -}}
# 1Password SSH Agent
Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
{{- end }}

# Includes MUST come before any named Host block. OpenSSH's Include
# directive inherits the surrounding Host context: when placed after a
# `Host github.com` block (or any other named Host), the included file's
# Host declarations get treated as nested under that parent and silently
# fail to apply for their stated targets. Verified 2026-05-10 with a
# minimal repro: `Host github.com` + `Include config.d/*` + a Host block
# inside the include → the include is *read* (verbose `-v` shows
# "Reading configuration data .../config.d/X") but *no* "Applying
# options" line, and `ssh -G` reports the wrong identity file. Moving
# Includes above the named-Host blocks fixes it cleanly.

# OrbStack Linux VMs
Include ~/.orbstack/ssh/config

# Modular host configs
Include config.d/*

{{ if stat (joinPath .chezmoi.homeDir ".ssh/id_ed25519_github") -}}
# Per-machine GitHub key (S-53 recipe; S-58 ratify). Block deploys only
# when ~/.ssh/id_ed25519_github exists; fresh machines without S-53 done
# get the 1P agent fallback (no block, no broken github SSH).
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_github
  IdentitiesOnly yes
{{- end }}
