#!/bin/sh
# ~/.local/bin/dotfiles-watcher-tick — one tick of the dotfiles watcher.
# Absorbs config drift into the dotfiles repo's working tree by calling
# `chezmoi re-add` on every drifted managed file. Triggered by:
#   ~/Library/LaunchAgents/com.truonghan.dotfiles-watcher.plist          (launchd WatchPaths)
#   ~/Library/LaunchAgents/com.truonghan.dotfiles-watcher-fswatch.plist  (fswatch -r daemon)
#
# Working-tree only: never commits, never pushes. Operator reviews via
# `git status` in the dotfiles repo and commits manually.

set -eu

LOG="${HOME}/Library/Logs/dotfiles-watcher.log"
LOCK="${HOME}/Library/Caches/dotfiles-watcher.lock"
mkdir -p "$(dirname "$LOG")" "$(dirname "$LOCK")"

# Atomic lock via mkdir (macOS doesn't ship /usr/bin/flock by default).
# If another tick is already in flight, exit silently — its drift loop will
# pick up our changes on its next pass. Stale locks from a previous crash
# are forgiven after 60s.
if [ -d "$LOCK" ]; then
    lock_mtime=$(stat -f %m "$LOCK" 2>/dev/null || echo 0)
    now=$(date +%s)
    age=$((now - lock_mtime))
    if [ "$age" -lt 60 ]; then
        exit 0
    fi
    rmdir "$LOCK" 2>/dev/null || true
fi
if ! mkdir "$LOCK" 2>/dev/null; then
    exit 0
fi
ENROLL_TMP=$(mktemp -t dotfiles-watcher-enroll.XXXXXX 2>/dev/null \
             || mktemp "${TMPDIR:-/tmp}/dotfiles-watcher-enroll.XXXXXX")
trap 'rmdir "$LOCK" 2>/dev/null || true; rm -f "$ENROLL_TMP" 2>/dev/null || true' EXIT

# Locate chezmoi. Test runners inject DOTFILES_CHEZMOI to point at a fake.
CHEZMOI="${DOTFILES_CHEZMOI:-}"
if [ -z "$CHEZMOI" ] || [ ! -x "$CHEZMOI" ]; then
    CHEZMOI=""
    for p in /opt/homebrew/bin/chezmoi /usr/local/bin/chezmoi "${HOME}/.local/bin/chezmoi"; do
        [ -x "$p" ] && CHEZMOI="$p" && break
    done
fi
if [ -z "$CHEZMOI" ]; then
    printf '%s ERROR chezmoi not found on PATH\n' "$(date -u +%FT%TZ)" >> "$LOG"
    exit 1
fi

# Auto-enroll globs (S-67): files matching these get `chezmoi add`-ed if they
# exist but aren't yet managed. Narrow on purpose; new entries here are the
# only way to extend enrollment behavior. The watcher does NOT scan arbitrary
# unmanaged files. See docs/specs/S-67-watcher-auto-enroll-roots.md.
AUTO_ENROLL_GLOBS="
${HOME}/.claude/skills/*/SKILL.md
"

iter=0
absorbed=0
enrolled=0
START_TS=$(date -u +%FT%TZ)

# ── Enrollment pass (S-67) ─────────────────────────────────────────
# Scan AUTO_ENROLL_GLOBS for files not yet in `chezmoi managed`. For each,
# run `chezmoi add`. The grep -Fxq short-circuit makes already-managed files
# free on subsequent ticks. Failures append to $LOG; tick continues regardless.
managed_set=$("$CHEZMOI" managed 2>/dev/null || true)

OLDIFS=$IFS
IFS='
'
for glob in $AUTO_ENROLL_GLOBS; do
    [ -z "$glob" ] && continue
    # AUTO_ENROLL_GLOBS is a hard-coded constant, never user input.
    # Eval is needed so the shell expands `*` in the glob.
    eval "set -- $glob"
    for f in "$@"; do
        [ -f "$f" ] || continue  # no-match → $f is the literal glob string
        rel="${f#"$HOME"/}"
        if ! printf '%s\n' "$managed_set" | grep -Fxq "$rel"; then
            printf '%s\n' "$rel" >> "$ENROLL_TMP"
        fi
    done
done
IFS=$OLDIFS

if [ -s "$ENROLL_TMP" ]; then
    printf '%s TICK start\n' "$START_TS" >> "$LOG"
    enrolled=1
    while IFS= read -r rel; do
        [ -z "$rel" ] && continue
        abs="${HOME}/${rel}"
        if "$CHEZMOI" add "$abs" >>"$LOG" 2>&1; then
            printf '  + enrolled %s\n' "$rel" >> "$LOG"
        fi
    done < "$ENROLL_TMP"
fi

# Drift loop: a file edited while a tick is mid-flight would be missed if we
# only checked once. Loop up to N times until chezmoi status is clean.
DRIFT_LOOP_MAX=3

while [ $iter -lt $DRIFT_LOOP_MAX ]; do
    # Coalesce a burst of editor-save events into a single pass.
    # Zed in particular writes settings.json 2-3 times within ~100ms.
    sleep 2

    # Match any "destination modified" row (chezmoi status format: SD where
    # D=destination). ` M `, `MM `, and `AM ` all mean the dest has drifted
    # and `chezmoi re-add` is the right action. ` A ` (new file untracked-by-chezmoi)
    # is intentionally skipped per S-64 § Out of scope.
    DRIFT=$("$CHEZMOI" status 2>/dev/null | awk '/^.M / {print substr($0,4)}')
    if [ -z "$DRIFT" ]; then
        break
    fi

    if [ $iter -eq 0 ] && [ $enrolled -eq 0 ]; then
        printf '%s TICK start\n' "$START_TS" >> "$LOG"
    fi

    echo "$DRIFT" | while IFS= read -r path; do
        [ -z "$path" ] && continue
        abs="${HOME}/${path}"
        if "$CHEZMOI" re-add "$abs" >>"$LOG" 2>&1; then
            printf '  + %s\n' "$path" >> "$LOG"
        fi
    done
    absorbed=1
    iter=$((iter + 1))
done

if [ $absorbed -eq 1 ] || [ $enrolled -eq 1 ]; then
    printf '%s TICK done (passes=%d)\n' "$(date -u +%FT%TZ)" "$iter" >> "$LOG"
fi
