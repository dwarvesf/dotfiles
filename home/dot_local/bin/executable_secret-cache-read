#!/bin/bash
# secret-cache-read — load 1Password-backed secrets via macOS Keychain cache.
#
# Two modes:
#
#   secret-cache-read VAR_NAME OP_REF
#     Single-pair mode. Echoes the resolved value (or empty on failure).
#     Used for ad-hoc invocation. ~17 ms per call (one Keychain read).
#
#   secret-cache-read --batch VAR1 REF1 [VAR2 REF2 ...]
#     Batch mode. Resolves N pairs in one bash invocation, emits
#     NUL-separated VAR\0VALUE\0VAR\0VALUE\0... on stdout. Saves ~15 ms
#     warm-fish-startup vs N separate forks; see S-61. The expensive
#     part is `security find-generic-password` itself (~13 ms × N,
#     kernel-side, irreducible). Batch only collapses bash-startup
#     amortization (~3 ms × N). Net win is real but modest.
#     OP_SERVICE_ACCOUNT_TOKEN, if present in the pairs, is resolved
#     first so subsequent `op read` fallbacks have bearer auth in env
#     (preserves the SA-token-first ordering, mirrors the template
#     comment chain).
#
# Resolution flow per pair (used by both modes via _load_one):
#   1. security find-generic-password    -> Keychain hit, silent
#   2. negative-cache check (24h TTL)    -> recent miss skips slow op read
#   3. fall back to `op read REF`        -> may trigger 1P popup
#   4. cache success in Keychain (-A)    -> silent next time, S-51
#   5. cache failure in $NEG_DIR         -> suppress op read for 24h
#   6. echo value (empty if all failed)
#
# Invalidate cache: `dotfiles secret refresh VAR`
set -eo pipefail

NEG_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/secret-cache-read"
NEG_TTL_SEC=86400  # 24h: dampens repeated startup tax on broken refs; self-heals daily.

# ── helpers ───────────────────────────────────────────────────────────
# Load one secret. Echoes value on success, returns 1 on failure.
# Side effects: caches successes in Keychain; caches failures in $NEG_DIR.
_load_one() {
    local var="$1" ref="$2" val=""
    local neg_file="$NEG_DIR/$var.miss"

    # 1. Keychain hit (silent after initial approval)
    if val=$(security find-generic-password -a "$USER" -s "$var" -w 2>/dev/null); then
        if [ -n "$val" ]; then
            # Clear any stale negative-cache marker. Keychain authoritatively wins.
            [ -f "$neg_file" ] && rm -f "$neg_file" 2>/dev/null
            printf '%s' "$val"
            return 0
        fi
    fi

    # 2. Negative cache: a recent op-read failure should not re-charge ~1.2s on
    # every shell. A bad ref otherwise burns startup-time forever silently.
    if [ -f "$neg_file" ]; then
        local now mtime
        now=$(date +%s)
        mtime=$(stat -f %m "$neg_file" 2>/dev/null || stat -c %Y "$neg_file" 2>/dev/null || echo 0)
        if [ $((now - mtime)) -lt $NEG_TTL_SEC ]; then
            return 1
        fi
    fi

    # 3. Fall back to 1Password (requires op CLI signed in; may trigger popup)
    if ! command -v op >/dev/null 2>&1; then
        return 1
    fi
    if ! val=$(op read "$ref" 2>/dev/null) || [ -z "$val" ]; then
        # op read failed (not signed in, wrong ref, network, ...).
        # Mark broken so subsequent shells skip the slow call until TTL expires.
        mkdir -p "$NEG_DIR" 2>/dev/null && touch "$neg_file" 2>/dev/null || true
        return 1
    fi

    # 4. Successful read: clear stale negative-cache + cache in Keychain.
    rm -f "$neg_file" 2>/dev/null || true
    # -A ("allow any application owned by the user") is required for cross-
    # Security-Session reads on multi-machine setups (S-51 rationale). Without
    # it, SSH-context reads are denied and fall through to op read, which
    # triggers a biometric popup that cannot be answered headlessly. Same
    # blast radius as the env-var model: any process the user runs can read.
    security add-generic-password -a "$USER" -s "$var" -w "$val" -A -U 2>/dev/null || true

    printf '%s' "$val"
}

# ── batch mode ────────────────────────────────────────────────────────
if [ "${1-}" = "--batch" ]; then
    shift
    [ $(( $# % 2 )) -eq 0 ] || {
        echo "secret-cache-read --batch: expected even number of args (VAR REF pairs), got $#" >&2
        exit 2
    }

    # Collect all pairs into parallel arrays.
    declare -a vars=() refs=()
    while [ $# -gt 0 ]; do
        vars+=("$1")
        refs+=("$2")
        shift 2
    done

    # Pass 1: resolve OP_SERVICE_ACCOUNT_TOKEN first (if present) so
    # subsequent `op read` calls in pass 2 inherit bearer auth via env.
    for i in "${!vars[@]}"; do
        if [ "${vars[i]}" = "OP_SERVICE_ACCOUNT_TOKEN" ]; then
            if val=$(_load_one "${vars[i]}" "${refs[i]}"); then
                printf '%s\0%s\0' "${vars[i]}" "$val"
                export OP_SERVICE_ACCOUNT_TOKEN="$val"
            else
                printf '%s\0\0' "${vars[i]}"
            fi
            unset 'vars[i]' 'refs[i]'
        fi
    done

    # Pass 2: remaining vars.
    for i in "${!vars[@]}"; do
        if val=$(_load_one "${vars[i]}" "${refs[i]}"); then
            printf '%s\0%s\0' "${vars[i]}" "$val"
        else
            printf '%s\0\0' "${vars[i]}"
        fi
    done
    exit 0
fi

# ── single-pair mode (legacy / ad-hoc) ────────────────────────────────
VAR="${1:?usage: secret-cache-read VAR_NAME OP_REF  |  --batch VAR1 REF1 ...}"
REF="${2:?usage: secret-cache-read VAR_NAME OP_REF  |  --batch VAR1 REF1 ...}"
_load_one "$VAR" "$REF" || true
