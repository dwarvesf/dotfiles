#!/bin/bash
# secret-cache-read VAR_NAME OP_REF
#
# Returns a secret value, preferring macOS Keychain (silent) over 1Password (popup).
# Used by ~/.config/fish/conf.d/secrets.fish to lazy-load secrets at shell startup.
#
# Flow:
#   1. Check Keychain for VAR_NAME              → hit returns immediately (silent)
#   2. Negative-cache check (24h TTL)           → recent miss skips slow op read
#   3. Keychain miss → op read OP_REF           → triggers 1Password popup (first time)
#   4. Cache result in Keychain for next time
#   5. Echo value (empty if all failed)
#
# Invalidate a cached secret with: dotfiles secret refresh VAR_NAME
set -eo pipefail

VAR="${1:?usage: secret-cache-read VAR_NAME OP_REF}"
REF="${2:?usage: secret-cache-read VAR_NAME OP_REF}"

NEG_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/secret-cache-read"
NEG_FILE="$NEG_DIR/$VAR.miss"
NEG_TTL_SEC=86400  # 24h: dampens repeated startup tax on broken refs; self-heals daily.

# 1. Keychain first (silent after initial approval)
if VAL=$(security find-generic-password -a "$USER" -s "$VAR" -w 2>/dev/null); then
    if [ -n "$VAL" ]; then
        # Clear any stale negative-cache marker — Keychain authoritatively wins.
        [ -f "$NEG_FILE" ] && rm -f "$NEG_FILE" 2>/dev/null
        printf '%s' "$VAL"
        exit 0
    fi
fi

# 2. Negative cache: a recent op-read failure shouldn't re-charge ~1.2s on every
# shell. A bad ref otherwise burns startup-time forever silently (failures are
# swallowed at line 30 below). Manual reset: `rm -f "$NEG_FILE"` or
# `dotfiles secret refresh VAR`.
if [ -f "$NEG_FILE" ]; then
    NOW=$(date +%s)
    MTIME=$(stat -f %m "$NEG_FILE" 2>/dev/null || stat -c %Y "$NEG_FILE" 2>/dev/null || echo 0)
    if [ $((NOW - MTIME)) -lt $NEG_TTL_SEC ]; then
        exit 0
    fi
fi

# 3. Fall back to 1Password (requires op CLI signed in — triggers popup)
if ! command -v op >/dev/null 2>&1; then
    # op not installed; fail silently so shell startup doesn't break
    exit 0
fi

if ! VAL=$(op read "$REF" 2>/dev/null); then
    # op read failed (not signed in, wrong ref, network issue, etc.)
    # Mark as broken so subsequent shells skip the slow call until TTL expires.
    mkdir -p "$NEG_DIR" 2>/dev/null && touch "$NEG_FILE" 2>/dev/null || true
    # Fail silently; $VAR will be empty, user can run `dotfiles secret refresh VAR`
    exit 0
fi

[ -z "$VAL" ] && {
    mkdir -p "$NEG_DIR" 2>/dev/null && touch "$NEG_FILE" 2>/dev/null || true
    exit 0
}

# Successful read: clear any stale negative-cache marker.
rm -f "$NEG_FILE" 2>/dev/null || true

# 3. Cache in Keychain for next time (silent — user already approved op call).
# -A ("allow any application owned by the user") is required for cross-session
# reads to succeed on multi-machine setups where the same secret is read both
# from a GUI-originated fish session AND from an SSH-originated session (S-51).
# Without -A, macOS binds the item's ACL to the originating process context;
# SSH-context reads are denied and `secret-cache-read` falls through to
# `op read`, which triggers a biometric popup that can't be answered headlessly.
# Same blast radius as the env-var model: any process the user runs can read.
security add-generic-password -a "$USER" -s "$VAR" -w "$VAL" -A -U 2>/dev/null || true

# 4. Return the value
printf '%s' "$VAL"
