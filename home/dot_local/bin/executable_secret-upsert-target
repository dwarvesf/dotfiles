#!/bin/bash
# secret-upsert-target — write (or rotate) a registered secret on one target.
#
# Used by `dotfiles secret push` to handle per-target keychain seeding.
# Pulled out of the fish wrapper because the per-target dance (probe, delete,
# add, verify, neg-cache cleanup) doubles in line count when expressed in fish
# quoting once you add remote sudo + heredocs. Mirrors the secret-cache-read
# split (S-61): fish does CLI/orchestration, bash does the keychain ops.
#
# Usage:
#   secret-upsert-target VAR_NAME BACKING_STORE TARGET < VALUE_ON_STDIN
#
# Args:
#   VAR_NAME       Registered secret name (e.g. OP_SERVICE_ACCOUNT_TOKEN).
#   BACKING_STORE  login | system. Selects which keychain to write to.
#                  - login:  ~/Library/Keychains/login.keychain-db (no sudo)
#                  - system: /Library/Keychains/System.keychain (sudo required)
#   TARGET         "local" or an SSH alias (e.g. mac-mini, build-host).
#
# Stdin: the secret value, one line, no trailing newline preferred.
#
# Output: a single ✓/✗ verdict line on stdout. Exit 0 on success, 1 on failure.
#
# Why delete-then-add and not `add -U`:
#   `add -U` works fine on login.keychain (per-user, no GUI gate on ACL update),
#   but fails on System.keychain over non-TTY SSH because macOS gates ACL
#   updates behind a GUI confirmation. Symptoms: "User interaction is not
#   allowed" + "specified item already exists", exit 0, no value change.
#   Delete-then-add subsumes seed + rotate cases for both backing stores at
#   the cost of one extra keychain op per call. See S-63 § Decision 2.
#
# Safe-form discipline (S-62):
#   - Value is read once from stdin into a bash local. Brief argv exposure
#     via `-w "$(cat)"` on the remote `add` is the same trade-off S-51 took.
#   - No printing of the value to stdout/stderr in any path.

set -eo pipefail

usage() {
    cat <<'EOF' >&2
Usage: secret-upsert-target VAR_NAME login|system local|<ssh-alias> < VALUE_ON_STDIN

Internal helper for `dotfiles secret push`. Not intended for direct use.
EOF
    exit 2
}

VAR="${1:-}"
BACKING="${2:-}"
TARGET="${3:-}"

[ -z "$VAR" ] && usage
[ -z "$BACKING" ] && usage
[ -z "$TARGET" ] && usage

case "$BACKING" in
    login|system) ;;
    *) echo "✗ $TARGET ($BACKING is not a valid backing store; use login or system)"; exit 1 ;;
esac

# Read value from stdin once. Empty value is a hard fail; rotating to empty
# would overwrite a working secret with nothing, which is the wrong default.
VALUE=$(cat)
if [ -z "$VALUE" ]; then
    echo "✗ $TARGET (empty value on stdin; refusing to overwrite)"
    exit 1
fi
PREFIX=$(printf '%s' "$VALUE" | head -c 4)

# Compose the per-step shell commands. KCSPEC is the keychain path argument
# (empty string = default login keychain). SUDO is the sudo prefix when
# writing to System.keychain. Same VAR/USER expansion happens on the target,
# so $USER inside the quoted strings is the target's $USER.
if [ "$BACKING" = "system" ]; then
    KCSPEC="/Library/Keychains/System.keychain"
    SUDO="sudo"
else
    KCSPEC=""
    SUDO=""
fi

# Quote-aware command builders. The remote shell is run via `bash -c '<cmd>'`,
# so $-references inside <cmd> resolve on the target. The outer single quotes
# in the bash -c invocation prevent local expansion.
DEL_CMD="$SUDO security delete-generic-password -a \"\$USER\" -s \"$VAR\" $KCSPEC >/dev/null 2>&1 || true"
ADD_CMD="$SUDO security add-generic-password -a \"\$USER\" -s \"$VAR\" -w \"\$(cat)\" -A -T /usr/bin/security -T /opt/homebrew/bin/op $KCSPEC 2>&1"
VERIFY_CMD="$SUDO security find-generic-password -a \"\$USER\" -s \"$VAR\" -w $KCSPEC 2>/dev/null | head -c 4"
NEGCLEAR_CMD='f="${XDG_CACHE_HOME:-$HOME/.cache}/secret-cache-read/'"$VAR"'.miss"; [ -f "$f" ] && rm -f "$f"; true'

# ── execute on local or remote ────────────────────────────────────────
if [ "$TARGET" = "local" ]; then

    # Probe sudo posture for system backing. `sudo -v` will prompt for
    # password if needed (and cache it), or no-op if already cached.
    if [ "$BACKING" = "system" ]; then
        if ! sudo -v 2>/dev/null; then
            echo "✗ local (sudo refresh failed; password required and not provided)"
            exit 1
        fi
    fi

    # Run the steps. ADD reads value via $(cat) on stdin.
    bash -c "$DEL_CMD"
    add_out=$(printf '%s' "$VALUE" | bash -c "$ADD_CMD" 2>&1) || true
    read_back=$(bash -c "$VERIFY_CMD" || true)
    bash -c "$NEGCLEAR_CMD"

else
    # Remote target. Probe SSH first; aborts before piping value if unreachable.
    if ! ssh -o BatchMode=yes -o ConnectTimeout=5 "$TARGET" true 2>/dev/null; then
        echo "✗ $TARGET (ssh unreachable: hostname or key auth issue)"
        exit 1
    fi

    # For system backing, passwordless sudo is a precondition. A sudo prompt
    # over piped SSH would hang, so we abort fast with an actionable message.
    if [ "$BACKING" = "system" ]; then
        if ! ssh "$TARGET" 'sudo -n true' 2>/dev/null; then
            echo "✗ $TARGET (passwordless sudo not configured; required for --backing-store=system)"
            exit 1
        fi
    fi

    # Delete (idempotent), then pipe value into add, then read back, then
    # neg-clear. Each step is its own SSH invocation so stdin handling is
    # explicit and non-ambiguous.
    ssh "$TARGET" "bash -c '$DEL_CMD'" 2>/dev/null || true
    add_out=$(printf '%s' "$VALUE" | ssh "$TARGET" "bash -c '$ADD_CMD'" 2>&1) || true
    read_back=$(ssh "$TARGET" "bash -c '$VERIFY_CMD'" 2>/dev/null || true)
    ssh "$TARGET" "bash -c '$NEGCLEAR_CMD'" 2>/dev/null || true
fi

# ── verify ────────────────────────────────────────────────────────────
if [ "$read_back" = "$PREFIX" ]; then
    echo "✓ $TARGET ($VAR seeded, verified by read-back)"
    exit 0
fi

# Failure: surface a useful reason. Common causes:
#   - "User interaction is not allowed": ACL gate (login keychain locked, or
#     System.keychain ACL update over no-TTY). Should not happen given the
#     delete-then-add design, but guard for it anyway.
#   - empty read_back: write succeeded but read fails (rare; permission ACL).
#   - other: dump add_out for the operator.
case "$add_out" in
    *"User interaction is not allowed"*)
        echo "✗ $TARGET (ACL gate; login keychain locked or System.keychain UI prompt blocked)"
        ;;
    *"already exists"*)
        echo "✗ $TARGET (delete step did not remove prior entry; check sudo + keychain path)"
        ;;
    *)
        if [ -z "$read_back" ]; then
            echo "✗ $TARGET (read-back returned empty; write likely failed silently)"
        else
            echo "✗ $TARGET (read-back prefix mismatch: expected '$PREFIX', got '$read_back')"
        fi
        ;;
esac
exit 1
