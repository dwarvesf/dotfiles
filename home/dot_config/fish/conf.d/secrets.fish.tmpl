{{- $e := printf "%c" 27 -}}
{{- if not (hasKey . "use_1password") -}}
{{-   fail (printf "\n\n%s[38;5;204m  ✗ Missing config variable: use_1password%s[0m\n    Run: %s[38;5;78mchezmoi init%s[0m\n" $e $e $e $e) -}}
{{- end -}}
# secrets.fish — Secret loading for fish shell.
#
# Auto-loaded secrets live in .chezmoidata/secrets.toml. Manage with:
#
#   dotfiles secret add VAR "op://Vault/Item/field"   # register
#   dotfiles secret rm VAR                            # unregister
#   dotfiles secret list                              # show bindings
#   dotfiles secret refresh VAR                       # force re-fetch from 1Password
#   dotfiles secret push VAR ssh-target               # seed remote machine's Keychain (S-51)
#
# Secrets are lazy-resolved at shell startup via secret-cache-read:
#   - Keychain hit → silent (no 1Password popup)
#   - Keychain miss → op read + cache (1Password popup on FIRST shell only)
#   - chezmoi apply NEVER calls 1Password
#
# Gate is `is-login`, not `is-interactive`. Both interactive login fish AND
# non-interactive `ssh user@host '<cmd>'` invocations load secrets, so SSH-
# driven flows (e.g. ops scripts on the Mini) inherit OP_SERVICE_ACCOUNT_TOKEN
# without a TTY. Plain `fish file.fish` script invocations are non-login and
# correctly skip this block. See S-51 for the rationale.
#
# For one-off loads without persistence: op-env / keychain-env.

if status is-login
{{ if .use_1password }}
    # ── 1Password-backed secrets (Keychain cache, lazy eval) ─────────
    set -l _sc $HOME/.local/bin/secret-cache-read
    # Load OP_SERVICE_ACCOUNT_TOKEN first so any later cache miss falls
    # through to `op read` with bearer auth already in env. Without this,
    # alphabetically-earlier vars (e.g. CLOUDFLARE_API_TOKEN) hit 1P
    # Desktop integration on cache miss; on remote shells, 1P attributes
    # the request to whatever ancestor binary it walks to (e.g.
    # `tailscaled` when Tailscale SSH is the transport). See S-54.
{{- if hasKey .secrets "OP_SERVICE_ACCOUNT_TOKEN" }}
    set -gx OP_SERVICE_ACCOUNT_TOKEN ($_sc "OP_SERVICE_ACCOUNT_TOKEN" "{{ index .secrets "OP_SERVICE_ACCOUNT_TOKEN" }}")
{{- end }}
{{- range $var, $ref := .secrets }}
{{-   if ne $var "OP_SERVICE_ACCOUNT_TOKEN" }}
    set -gx {{ $var }} ($_sc "{{ $var }}" "{{ $ref }}")
{{-   end }}
{{- end }}
{{ else }}
    # 1Password not configured. Enable: chezmoi init (answer "yes" to 1Password)
{{ end }}
    # ── macOS Keychain (ad-hoc) ───────────────────────────────────────
    # Store: security add-generic-password -a "$USER" -s "MY_TOKEN" -w "secret123" -U
    # Load:  keychain-env MY_TOKEN
end
