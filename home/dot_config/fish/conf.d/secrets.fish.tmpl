{{- $e := printf "%c" 27 -}}
{{- if not (hasKey . "use_1password") -}}
{{-   fail (printf "\n\n%s[38;5;204m  ✗ Missing config variable: use_1password%s[0m\n    Run: %s[38;5;78mchezmoi init%s[0m\n" $e $e $e $e) -}}
{{- end -}}
# secrets.fish — Secret loading for fish shell.
#
# Auto-loaded secrets live in .chezmoidata/secrets.toml. Manage with:
#
#   dotfiles secret add VAR "op://Vault/Item/field"   # register
#   dotfiles secret rm VAR                            # unregister
#   dotfiles secret list                              # show bindings
#   dotfiles secret refresh VAR                       # force re-fetch from 1Password
#
# Secrets are lazy-resolved at shell startup via secret-cache-read:
#   - Keychain hit → silent (no 1Password popup)
#   - Keychain miss → op read + cache (1Password popup on FIRST shell only)
#   - chezmoi apply NEVER calls 1Password
#
# For one-off loads without persistence: op-env / keychain-env.

if status is-interactive
{{ if .use_1password }}
    # ── 1Password-backed secrets (Keychain cache, lazy eval, batched) ─
    # Single bash invocation for N secrets. Saves ~50 ms vs N forks at
    # shell startup. The script resolves OP_SERVICE_ACCOUNT_TOKEN first
    # internally so any later `op read` fallback has bearer auth in env
    # (S-54 ordering preserved). Output is NUL-separated VAR\0VALUE
    # pairs; we split and `set -gx` each. See S-55.
{{- if .secrets }}
    set -l _pairs ($HOME/.local/bin/secret-cache-read --batch{{ range $var, $ref := .secrets }} {{ $var }} "{{ $ref }}"{{ end }} | string split0)
    for _i in (seq 1 2 (count $_pairs))
        set -gx $_pairs[$_i] $_pairs[(math $_i + 1)]
    end
    set -e _pairs _i
{{- end }}
{{ else }}
    # 1Password not configured. Enable: chezmoi init (answer "yes" to 1Password)
{{ end }}
    # ── macOS Keychain (ad-hoc) ───────────────────────────────────────
    # Store: security add-generic-password -a "$USER" -s "MY_TOKEN" -w "secret123" -U
    # Load:  keychain-env MY_TOKEN
end
